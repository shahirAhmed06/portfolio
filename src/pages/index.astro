---
import Layout from '../layouts/Layout.astro';
import TickRule from '../components/TickRule.astro';
import CoordLine from '../components/CoordLine.astro';
import ProjectBlock from '../components/ProjectBlock.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('projects', ({ data }) => !data.draft);

// Featured on homepage — order matches the selected-work direction in the design
const featuredSlugs = ['gb-emulator', 'riscv-cpu', 'electrochemical-analyzer'];
const featured = featuredSlugs
  .map((s) => all.find((p) => p.slug === s))
  .filter((p): p is NonNullable<typeof p> => p !== undefined);

const roles = [
  { title: 'Undergraduate Researcher',     org: 'MICROTECHNOLOGY LAB, MSU',  period: '2025—', href: '/research/microtechnology-lab' },
  { title: 'Undergraduate Researcher',     org: 'RF-PHOTONICS LAB, MSU',     period: '2026—', href: '/research/rf-photonics-lab' },
  { title: 'Vehicle Controls & Sensing',   org: 'MSU SOLAR CAR RACING',      period: '2025—', href: '/involvement/solar-car-racing' },
  { title: 'Technical Director',           org: 'IEEE MSU STUDENT BRANCH',   period: '2026—', href: '/involvement/ieee-msu' },
];
---

<Layout title="Shahir Ahmed — Electrical Engineering at MSU">

  <TickRule />

  <!-- HERO ──────────────────────────────────────────── -->
  <section
    aria-labelledby="hero-heading"
    class="mx-auto max-w-container px-6 sm:px-8 pt-12 sm:pt-16 pb-16 sm:pb-20"
  >
    <CoordLine page="/" class="sm:mb-12" revealIndex={0} />

    <h1
      id="hero-heading"
      class="font-display text-display text-fg m-0 text-balance reveal-item"
      style="--i: 1; font-variation-settings: 'opsz' 96, 'wdth' 100"
    >
      Shahir<br />Ahmed<span class="text-accent">.</span>
    </h1>

    <div class="mt-10 grid gap-10 md:grid-cols-2">
      <p class="font-mono text-lede text-fg-secondary m-0 max-w-ch60 text-pretty reveal-item" style="--i: 2;">
        Undergraduate electrical engineer at Michigan&nbsp;State, working across
        microelectronics, embedded systems, digital design, and RF, from
        electrochemical sensing to FPGAs and software-defined radio.
      </p>

      <ol
        role="list"
        aria-label="Current roles"
        class="list-none m-0 p-0 flex flex-col gap-4"
      >
        {roles.map((role, i) => (
          <li class="reveal-item" style={`--i: ${3 + i};`}>
            <a href={role.href} class="group flex items-baseline gap-4 no-underline">
              <span
                class="font-mono text-coord text-accent flex-shrink-0"
                aria-hidden="true"
              >
                {String(i + 1).padStart(2, '0')}
              </span>
              <div class="flex-1 min-w-0">
                <div class="font-mono text-meta text-fg transition-colors group-hover:text-accent">
                  {role.title}
                </div>
                <div class="font-mono text-coord text-fg-muted mt-1">
                  {role.org} · {role.period}
                </div>
              </div>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ACCENT RULE ───────────────────────────────────── -->
  <div class="mx-auto max-w-container px-6 sm:px-8 reveal-item" style="--i: 7;">
    <div class="accent-rule"></div>
  </div>

  <!-- PROJECTS ──────────────────────────────────────── -->
  <section
    aria-labelledby="projects-heading"
    class="mx-auto max-w-container px-6 sm:px-8 pt-16 sm:pt-20 pb-20 sm:pb-24"
  >
    <header class="flex flex-wrap items-end justify-between gap-6 mb-10 reveal-item" style="--i: 8;">
      <div>
        <div class="font-mono text-micro uppercase text-fg-muted mb-3">
          / SELECTED WORK
        </div>
        <h2
          id="projects-heading"
          class="font-display text-h2 text-fg m-0 text-balance"
          style="font-variation-settings: 'opsz' 64"
        >
          Projects<span class="text-accent">.</span>
        </h2>
      </div>
      <a href="/projects" class="btn-ghost">ALL PROJECTS <span aria-hidden="true">→</span></a>
    </header>

    <div class="border-b border-rule">
      {featured.map((project, i) => (
        <ProjectBlock
          index={i + 1}
          title={project.data.title}
          summary={project.data.summary}
          role={project.data.role}
          tools={project.data.tools}
          date={project.data.date}
          repo={project.data.repo}
          revealIndex={9 + i}
          href={`/projects/${project.slug}`}
        />
      ))}
    </div>
  </section>

</Layout>
