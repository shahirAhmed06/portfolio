---
import Layout from '../layouts/Layout.astro';
import TickRule from '../components/TickRule.astro';
import CoordLine from '../components/CoordLine.astro';
import HeroMedia from '../components/HeroMedia.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('research', ({ data }) => !data.draft);

// Manually ordered — most relevant work first, independent of entry date
const order = ['rf-photonics-lab', 'microtechnology-lab', 'uuraf-2026-lightning-connectors'];
const items = order
  .map((slug) => all.find((item) => item.slug === slug))
  .filter((item): item is NonNullable<typeof item> => item !== undefined);

const typeLabels: Record<'lab-work' | 'conference' | 'paper-reading', string> = {
  'lab-work': 'LAB WORK',
  'conference': 'CONFERENCE',
  'paper-reading': 'PAPER READING',
};
---

<Layout
  title="Research — Shahir Ahmed"
  description="Undergraduate research in electrochemical sensing and microelectronics at Michigan State University."
>
  <TickRule />

  <div class="mx-auto max-w-container px-6 sm:px-8 pt-16 pb-28">
    <CoordLine page="/research" />

    <h1
      class="font-display text-h1 text-fg m-0 mb-14 text-balance"
      style="font-variation-settings: 'opsz' 72"
    >
      Research<span class="text-accent">.</span>
    </h1>

    <div class="border-t border-rule mb-16">
      {items.map((item) => (
        <a
          href={`/research/${item.slug}`}
          class:list={[
            'group no-underline grid gap-6 md:gap-8 border-b border-rule py-10',
            item.data.media[0] ? 'md:grid-cols-[minmax(0,_1fr)_280px]' : 'grid-cols-1',
          ]}
        >
          <div class="min-w-0">
            <div class="font-mono text-micro text-fg-muted uppercase mb-4">
              / {typeLabels[item.data.type]}
            </div>
            <h2
              class="font-display text-h3 text-fg m-0 mb-3 text-balance transition-colors group-hover:text-accent"
              style="font-variation-settings: 'opsz' 48"
            >
              {item.data.title}
            </h2>
            <p class="font-mono text-lede text-fg-secondary m-0 max-w-ch60">
              {item.data.summary}
            </p>
            {item.data.award && (
              <div class="meta-cluster mt-5">
                <span>AWARD / {item.data.award}</span>
              </div>
            )}
          </div>
          {item.data.media[0] && (
            <div class="md:self-start">
              <HeroMedia hero={item.data.media[0]} aspectRatio="16/9" label="MEDIA" preferStill={true} />
            </div>
          )}
        </a>
      ))}
    </div>
  </div>
</Layout>
