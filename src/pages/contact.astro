---
import Layout from '../layouts/Layout.astro';
import TickRule from '../components/TickRule.astro';
import CoordLine from '../components/CoordLine.astro';

interface ContactItem {
  label: string;
  value: string;
  href?: string;
  note?: string;
}

const items: ContactItem[] = [
  {
    label: 'EMAIL',
    value: 'ahmeds2609@gmail.com',
    href: 'mailto:ahmeds2609@gmail.com',
    note: 'best way to reach me.',
  },
  {
    label: 'LINKEDIN',
    value: 'linkedin.com/in/ahmeds60',
    href: 'https://www.linkedin.com/in/ahmeds60',
    note: 'professional network, open to connecting.',
  },
  {
    label: 'GITHUB',
    value: 'github.com/shahirAhmed06',
    href: 'https://github.com/shahirAhmed06',
    note: 'code and hardware projects.',
  },
  {
    label: 'LOCATION',
    value: 'East Lansing, MI',
    note: 'Michigan State University.',
  },
  {
    label: 'AVAILABILITY',
    value: 'Open to internships and co-ops.',
  },
];
---

<Layout
  title="Contact — Shahir Ahmed"
  description="Get in touch with Shahir Ahmed."
>
  <TickRule />

  <div class="mx-auto max-w-container px-6 sm:px-8 pt-16 pb-28">
    <CoordLine page="/contact" />

    <h1
      class="font-display text-h1 text-fg m-0 mb-12 text-balance"
      style="font-variation-settings: 'opsz' 72"
    >
      Contact<span class="text-accent">.</span>
    </h1>

    <div class="grid gap-10 md:gap-12 md:grid-cols-[minmax(0,_1fr)_320px] md:items-start">
      <ul role="list" class="list-none m-0 p-0 border-t border-rule">
        {items.map(({ label, value, href, note }, i) => {
          const isExternal = href?.startsWith('http');
          return (
            <li class="flex items-baseline gap-4 py-5 border-b border-rule">
              <span
                class="font-mono text-coord text-accent flex-shrink-0"
                aria-hidden="true"
              >
                {String(i + 1).padStart(2, '0')}
              </span>
              <div class="flex-1 min-w-0">
                <div class="font-mono text-micro uppercase text-fg-muted mb-1">
                  / {label}
                </div>
                <div class="font-mono text-body">
                  {href ? (
                    <a
                      href={href}
                      class="text-fg hover:text-accent transition-colors"
                      {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
                    >
                      {value}
                    </a>
                  ) : (
                    <span class="text-fg">{value}</span>
                  )}
                  {note && <span class="text-fg-muted"> — {note}</span>}
                </div>
              </div>
            </li>
          );
        })}
      </ul>

      <img
        src="/images/shahirAhmed.jpeg"
        alt="Shahir Ahmed"
        class="w-full max-w-[320px] border border-rule block"
        loading="lazy"
      />
    </div>
  </div>
</Layout>
