---
import Layout from '../../layouts/Layout.astro';
import TickRule from '../../components/TickRule.astro';
import CoordLine from '../../components/CoordLine.astro';
import ProjectBlock from '../../components/ProjectBlock.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const projects = allProjects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout
  title="Projects — Shahir Ahmed"
  description="Digital design, embedded firmware, SDR, and PCB projects by Shahir Ahmed."
>
  <TickRule />

  <div class="mx-auto max-w-container px-6 sm:px-8 pt-16 pb-28">
    <CoordLine page="/projects" />

    <h1
      class="font-display text-h1 text-fg m-0 mb-14 text-balance"
      style="font-variation-settings: 'opsz' 72"
    >
      Projects<span class="text-accent">.</span>
    </h1>

    <div>
      {projects.map((project, i) => (
        <ProjectBlock
          index={i + 1}
          title={project.data.title}
          summary={project.data.summary}
          status={project.data.status}
          role={project.data.role}
          tools={project.data.tools}
          date={project.data.date}
          repo={project.data.repo}
          headingLevel={2}
          href={`/projects/${project.slug}`}
          hero={project.data.media[0]}
          showHero={true}
        />
      ))}
      <div class="border-b border-rule"></div>
    </div>
  </div>
</Layout>
