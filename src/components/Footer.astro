---
import TickRule from './TickRule.astro';

const build = new Date().toISOString().slice(0, 10).replace(/-/g, '.');

const socials = [
  { label: 'LINKEDIN', href: 'https://www.linkedin.com/in/ahmeds60', newTab: true },
  { label: 'GITHUB',   href: 'https://github.com/shahirAhmed06',     newTab: true },
  { label: 'RESUME',   href: '/resume.pdf',                          newTab: true },
];
---

<footer class="border-t border-rule">
  <div class="mx-auto max-w-container px-6 sm:px-8 py-10">
    <div class="flex flex-col gap-6 sm:flex-row sm:flex-wrap sm:items-start sm:justify-between">
      <address class="not-italic font-mono flex flex-col gap-1">
        <a
          href="mailto:ahmeds2609@gmail.com"
          class="text-meta text-fg-secondary hover:text-fg transition-colors duration-fast"
        >
          ahmeds2609@gmail.com
        </a>
        <div class="text-coord text-fg-muted uppercase">
          {socials.map(({ label, href, newTab }, i) => (
            <>
              {i > 0 && ' / '}
              <a
                href={href}
                class="hover:text-fg transition-colors duration-fast"
                {...(newTab ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                {label}
              </a>
            </>
          ))}
        </div>
      </address>

      <div class="font-mono text-coord text-fg-muted uppercase sm:text-right flex flex-col gap-1">
        <span>BUILD {build}</span>
        <span>EAST LANSING, MI</span>
      </div>
    </div>

    <div class="mt-8">
      <TickRule variant="footer" />
    </div>
  </div>
</footer>
