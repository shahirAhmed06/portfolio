---
import Badge from './Badge.astro';
import HeroMedia from './HeroMedia.astro';

interface HeroImage { type: 'image'; src: string; alt: string; caption?: string }
interface HeroVideo { type: 'video'; src: string; poster?: string; alt: string; caption?: string }
type Hero = HeroImage | HeroVideo;

interface Props {
  index: number;
  title: string;
  summary: string;
  status: 'complete' | 'in-progress' | 'ongoing';
  role: string;
  tools: string[];
  date: Date;
  repo?: string;
  revealIndex?: number;
  headingLevel?: 2 | 3;
  href?: string;
  hero?: Hero;
  showHero?: boolean;
}

const {
  index,
  title,
  summary,
  status,
  role,
  tools,
  date,
  repo,
  revealIndex,
  headingLevel = 3,
  href,
  hero,
  showHero = false,
} = Astro.props;
const year = date.getFullYear();
const num = String(index).padStart(2, '0');
const Heading = headingLevel === 2 ? 'h2' : 'h3';
const Wrapper = href ? 'a' : 'article';

// Strip the scheme so the meta line reads `github.com/user/repo`, matching
// the bare monospace style of the ROLE / TOOLS entries beside it.
const repoLabel = repo?.replace(/^https?:\/\//, '');

const renderHero = showHero && !!hero;
const gridCols = renderHero
  ? 'grid-cols-[auto_1fr] md:grid-cols-[140px_minmax(0,_1fr)_280px]'
  : 'grid-cols-[auto_1fr] md:grid-cols-[160px_1fr]';
---

<Wrapper
  {...(href ? { href } : {})}
  class:list={[
    'border-t border-rule py-10 grid gap-6 md:gap-8',
    gridCols,
    { 'reveal-item': revealIndex !== undefined },
    { 'group no-underline': !!href },
  ]}
  style={revealIndex !== undefined ? `--i: ${revealIndex};` : undefined}
>
  <div class="flex flex-col gap-4 md:gap-5">
    <span
      class="font-display text-index text-accent leading-none"
      style="font-variation-settings: 'opsz' 96, 'wdth' 85"
      aria-hidden="true"
    >
      {num}
    </span>
    <div class="flex flex-col gap-1">
      {status === 'complete' ? (
        <>
          <span class="font-mono text-micro uppercase text-fg-muted">Complete</span>
          <span class="font-mono text-micro uppercase text-fg-muted">{year}</span>
        </>
      ) : (
        <>
          <Badge status={status} />
          <span class="font-mono text-micro uppercase text-fg-muted mt-1">{year}</span>
        </>
      )}
    </div>
  </div>

  <div class="min-w-0">
    <Heading
      class:list={[
        'font-display text-h3 text-fg m-0 mb-3 text-balance',
        { 'transition-colors group-hover:text-accent': !!href },
      ]}
      style="font-variation-settings: 'opsz' 48"
    >
      {title}
    </Heading>
    <p class="font-mono text-lede text-fg-secondary m-0 max-w-ch60">
      {summary}
    </p>
    <div class="meta-cluster mt-5">
      <span>ROLE / {role}</span>
      <span>TOOLS / {tools.join(', ')}</span>
      {repoLabel && <span>REPO / {repoLabel}</span>}
    </div>
  </div>

  {renderHero && (
    <div class="col-span-2 md:col-span-1 md:self-start">
      <HeroMedia hero={hero} aspectRatio="16/9" label="MEDIA" preferStill={true} />
    </div>
  )}
</Wrapper>
